{
  "name": "afm-sound-library",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "deploy": "vite build && firebase deploy --only hosting -P default",
    "deploy:dev": "vite build --mode development && firebase deploy --only hosting -P dev",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "set-admin": "node scripts/set-admin-claims.cjs"
  },
  "dependencies": {
    "firebase": "^12.16.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "dotenv": "^17.4.2",
    "firebase-admin": "^13.10.0",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
